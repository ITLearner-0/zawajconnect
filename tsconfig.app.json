{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting - Progressive Strict Mode Activation */
    /* Step 1: Enable basic type safety (ACTIVE) */
    "noImplicitAny": true,                    // Prevent implicit 'any' types
    "strictNullChecks": true,                 // Strict null and undefined checks
    "noFallthroughCasesInSwitch": true,      // Prevent switch fallthrough bugs

    /* Step 2: Enable soon (fix existing issues first) */
    "strict": false,                          // TODO: Enable after fixing existing issues
    "noUnusedLocals": false,                  // TODO: Enable and clean up unused variables
    "noUnusedParameters": false,              // TODO: Enable and clean up unused parameters

    /* Additional safety features */
    "strictFunctionTypes": true,              // Strict function type checking
    "noImplicitReturns": true,               // Ensure all code paths return a value
    "noUncheckedIndexedAccess": true,        // Add undefined to index signature results

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
