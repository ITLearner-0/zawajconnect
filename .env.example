# Supabase Configuration
# Get these values from https://app.supabase.com/project/_/settings/api

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon/public key (safe to use in client-side code)
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here

# Your Supabase project ID (found in project settings)
VITE_SUPABASE_PROJECT_ID=your_project_id_here

# Optional: Development mode flag (auto-detected by Vite)
# NODE_ENV=development

# Development Tools (set to 'true' to enable test user selector and dev tools)
VITE_DEV_MODE=false

# Optional: Braintree Configuration (for payments)
# VITE_BRAINTREE_TOKEN_URL=your_braintree_token_url
# VITE_BRAINTREE_MERCHANT_ID=your_merchant_id

# Optional: Google Meet Integration
# VITE_GOOGLE_MEET_API_KEY=your_google_meet_api_key

# Error Monitoring (Sentry) - Highly recommended for production
# Get DSN from https://sentry.io/settings/projects/
# 1. Create a Sentry account at https://sentry.io
# 2. Create a new project for your app
# 3. Copy the DSN from the project settings
# 4. For build-time source maps upload, get an auth token from https://sentry.io/settings/account/api/auth-tokens/
VITE_SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
VITE_SENTRY_ENVIRONMENT=production
VITE_APP_VERSION=1.0.0

# Sentry Build Configuration (for source maps upload)
# Only needed for production builds, not required for development
# SENTRY_ORG=your-organization-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=your-auth-token-here

# Optional: Analytics
# VITE_ANALYTICS_ID=your_analytics_id

# ⚠️ IMPORTANT NOTES:
# - Never commit this file with real values
# - Copy this file to .env and fill in your actual values
# - All VITE_ prefixed variables are exposed to the client
# - Never put sensitive secrets in VITE_ variables
# - Keep .env in .gitignore
